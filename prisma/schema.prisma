generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  yahooUserId  String   @unique
  accessToken  String
  refreshToken String
  tokenExpiry  DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  leagues      League[]
}

model League {
  id         String   @id @default(cuid())
  leagueKey  String   @unique
  name       String
  season     String
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  teams      Team[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Team {
  id              String            @id @default(cuid())
  teamKey         String            @unique
  name            String
  leagueId        String
  league          League            @relation(fields: [leagueId], references: [id])
  rosterSnapshots RosterSnapshot[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model Player {
  id             String         @id @default(cuid())
  playerKey      String         @unique
  name           String
  position       String
  nbaTeam        String
  injuryStatus   String?
  imageUrl       String?
  rosterEntries  RosterEntry[]
  statLines      StatLine[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model RosterSnapshot {
  id           String        @id @default(cuid())
  teamId       String
  team         Team          @relation(fields: [teamId], references: [id])
  snapshotDate DateTime      @default(now())
  entries      RosterEntry[]
  createdAt    DateTime      @default(now())
}

model RosterEntry {
  id               String         @id @default(cuid())
  rosterSnapshotId String
  rosterSnapshot   RosterSnapshot @relation(fields: [rosterSnapshotId], references: [id])
  playerId         String
  player           Player         @relation(fields: [playerId], references: [id])
  rosterSlot       String
  createdAt        DateTime       @default(now())
}

model StatLine {
  id         String   @id @default(cuid())
  playerId   String
  player     Player   @relation(fields: [playerId], references: [id])
  date       DateTime
  pts        Float?
  reb        Float?
  ast        Float?
  stl        Float?
  blk        Float?
  tov        Float?
  threepm    Float?
  fgPct      Float?
  ftPct      Float?
  createdAt  DateTime @default(now())

  @@unique([playerId, date])
}